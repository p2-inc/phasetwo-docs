{
  "name": "phasetwo-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "docusaurus start --host 0.0.0.0",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "serve": "docusaurus serve",
    "clear": "docusaurus clear",
    "clean": "rm -rf node_modules pnpm-lock.yaml package-lock.json dist dist_keycloak",
    "gen-api-docs": "docusaurus gen-api-docs all",
    "clean-api-docs": "docusaurus clean-api-docs all",
    "regen-api-docs": "npm run clean-api-docs && npm run gen-api-docs && rm api/sidebar.ts",
    "fmt": "prettier --write \"**/*.{js,jsx,ts,tsx,css,md,mdx,json}\" --ignore-path .gitignore",
    "fmt:check": "prettier --check \"**/*.{js,jsx,ts,tsx,css,md,mdx,json}\" --ignore-path .gitignore"
  },
  "dependencies": {
    "@docsearch/core": "4.5.0",
    "@docusaurus/core": "^3.10.1",
    "@docusaurus/faster": "^3.10.1",
    "@docusaurus/plugin-client-redirects": "^3.10.1",
    "@docusaurus/plugin-content-blog": "^3.10.1",
    "@docusaurus/preset-classic": "^3.10.1",
    "@docusaurus/theme-common": "^3.10.1",
    "@docusaurus/theme-live-codeblock": "^3.10.1",
    "@docusaurus/theme-mermaid": "^3.10.1",
    "@headlessui/react": "^2.2.9",
    "@iconify/react": "^5.2.1",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "docusaurus-plugin-openapi-docs": "^5.0.2",
    "docusaurus-theme-openapi-docs": "^5.0.2",
    "gsap": "^3.14.2",
    "jose": "^6.2.3",
    "keycloak-js": "^19.0.3",
    "path-browserify": "1.0.1",
    "radix-ui": "^1.4.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-fast-marquee": "^1.6.5",
    "swagger-ui-react": "^5.32.4"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "baseline-browser-mapping": "^2.10.13",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^3.4.19"
  },
  "packageManager": "pnpm@11.1.3"
}
